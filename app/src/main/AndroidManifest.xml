<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!-- Broad access to /storage/emulated/0 so phosh/Nautilus can see the phone's
         Downloads, Pictures, Documents etc. User must toggle this in system
         settings after install. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".PhoshdroidApp"
        android:requestLegacyExternalStorage="true"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Phoshdroid"
        android:extractNativeLibs="true"
        tools:replace="android:theme">

        <activity
            android:name=".LauncherActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".proot.ProotService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- Termux:X11 Wayland compositor activity (merged from termux-x11-app library).
             Override exported=false so it is not accessible outside this APK. -->
        <activity
            android:name="com.termux.x11.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            tools:replace="android:exported,android:launchMode" />

        <!-- Prevent LoriePreferences from auto-launching -->
        <activity
            android:name="com.termux.x11.LoriePreferences"
            android:enabled="false"
            tools:replace="android:enabled" />

    </application>
</manifest>
